{
  "name": "flipkart-clone-server",
  "version": "1.0.0",
  "description": "Backend API for Flipkart Clone E-Commerce Application",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "prisma": "^6.6.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
